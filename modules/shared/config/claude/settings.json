{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "marimo-pair@marimo-pair": true,
    "skill-creator@claude-plugins-official": true,
    "compose-notebook@scientific-skills": true,
    "emacs-pair@afermg-emacs-pair": true,
    "autoresearch@autoresearch": true
  },
  "extraKnownMarketplaces": {
    "marimo-pair": {
      "source": {
        "source": "github",
        "repo": "marimo-team/marimo-pair"
      },
      "autoUpdate": true
    },
    "scientific-skills": {
      "source": {
        "source": "github",
        "repo": "afermg/scientific-skills"
      }
    },
    "afermg-emacs-pair": {
      "source": {
        "source": "github",
        "repo": "afermg/emacs-pair"
      },
      "autoUpdate": true
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "showClearContextOnPlanAccept": true,
  "disableAutoMode": "disable",
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "IS_DEMO": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  }
}
