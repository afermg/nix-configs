defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.msmtp.log

# === Account: quasimorphic ===
# Port 587 is blocked on the network the user connects from: TCP accepts but
# no SMTP banner arrives, hanging msmtp on recvfrom. Multiple unrelated
# providers (mxroute + Gmail) fail identically, so it's a local-network
# transparent-proxy / firewall issue, not server-side. Port 465 (implicit
# TLS / submissions) works for both accounts.
account quasimorphic
host witcher.mxrouting.net
port 465
from alan@quasimorphic.com
user alan@quasimorphic.com
passwordeval "rbw get 'Quasimorphic Email'"
tls_starttls   off

# === Account: broad ===
# Same 587 blackhole as quasimorphic; Gmail accepts implicit TLS on 465.
account broad
host smtp.gmail.com
port 465
from amunozgo@broadinstitute.org
user amunozgo@broadinstitute.org
passwordeval "rbw get 'Broad Email App Password'"
tls_starttls off

# Default account
account default : quasimorphic
